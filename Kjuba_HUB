	local function canAttack(player)
		if not player or player == LocalPlayer or not player.Character then return false end
		local char = player.Character
		local hum = char:FindFirstChild("Humanoid")
	
		if not hum or hum.Health <= 0 or char:FindFirstChildOfClass("ForceField") then return false end
	
		-- Ignoruje specifické týmy
		local teamName = player.Team and player.Team.Name or ""
		if teamName == "Prisoners" or teamName == "Inmates" then return false end
	
		if teamCheckEnabled then
			local sameTeam = (player.Team == LocalPlayer.Team) or (player.TeamColor == LocalPlayer.TeamColor)
			if sameTeam then return false end
		end
	
		return true
	end
	
	-- 2. FUNKCE PRO ÚTOK (VYLEPŠENO PRO TRENCH WAR)
	local function forceAttack(targetChar)
		local tool = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Tool")
		if not tool then return end
	
		tool:Activate()
	
		-- Hledání RemoteEventu pro poškození (Trench War/ACS/Carbon fix)
		-- Hry často používají eventy jako "Hit", "Fire", "Damage" nebo "Remote"
		local event = tool:FindFirstChild("Hit") or tool:FindFirstChild("Damage") or tool:FindFirstChild("Fire") or tool:FindFirstChildOfClass("RemoteEvent")
	
		if event and event:IsA("RemoteEvent") then
			-- Simulace zásahu do hlavy (Headshot)
			local head = targetChar:FindFirstChild("Head")
			if head then
				-- Posíláme serveru informaci o zásahu (argumenty se liší podle hry)
