		sound.Name = "EmoteSound"
		sound.SoundId = "rbxassetid://130990339683290"
		sound.Parent = rootPart
		sound.Looped = true
		sound.RollOffMaxDistance = 150
		sound.Volume = 4
		sound.PlaybackSpeed = 0.7
	
