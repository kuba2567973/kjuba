	local savedFlySpeed = SM.get("fly_speed", nil)
	if savedFlySpeed then
		speedInput.Text = tostring(savedFlySpeed)
	end
	
	local function stopFlying()
		isFlying = false
		RunService:UnbindFromRenderStep("UniversalFly")
		if bv then bv:Destroy() bv = nil end
		if bg then bg:Destroy() bg = nil end
		currentTarget = nil
	
		local char = player.Character
		local hum = char and char:FindFirstChildOfClass("Humanoid")
		if hum and not hum.SeatPart then
			hum.PlatformStand = false
			hum:ChangeState(Enum.HumanoidStateType.GettingUp)
		end
	end
	
	local function startFlying()
		local char = player.Character
		local root = char and char:FindFirstChild("HumanoidRootPart")
		local hum = char and char:FindFirstChildOfClass("Humanoid")
		if not root or not hum then return end
	
		isFlying = true
		currentTarget = hum.SeatPart or root
	
		bv = Instance.new("BodyVelocity")
		bv.MaxForce = Vector3.new(1,1,1) * math.huge
		bv.Parent = currentTarget
	
		bg = Instance.new("BodyGyro")
		bg.MaxTorque = Vector3.new(2,2,2) * math.huge
		bg.P = 3000
		bg.D = 500
		bg.Parent = currentTarget
	
		RunService:BindToRenderStep("UniversalFly", 200, function()
			local speed = tonumber(speedInput.Text) or 60
			local dir = Vector3.new(0,0,0)
	
			-- AUTO-SWITCH: If you jump out of a car, move fly forces to YOU
			if hum.SeatPart == nil and currentTarget ~= root then
				bv.Parent = root
				bg.Parent = root
				currentTarget = root
			end
	
			if not UIS:GetFocusedTextBox() then
				if UIS:IsKeyDown(Enum.KeyCode.W) then dir += camera.CFrame.LookVector end
				if UIS:IsKeyDown(Enum.KeyCode.S) then dir -= camera.CFrame.LookVector end
				if UIS:IsKeyDown(Enum.KeyCode.A) then dir -= camera.CFrame.RightVector end
				if UIS:IsKeyDown(Enum.KeyCode.D) then dir += camera.CFrame.RightVector end
				if UIS:IsKeyDown(Enum.KeyCode.Space) then dir += Vector3.new(0,1,0) end
				if UIS:IsKeyDown(Enum.KeyCode.LeftControl) then dir -= Vector3.new(0,1,0) end
			end
	
			bv.Velocity = dir.Magnitude > 0 and (dir.Unit * speed) or Vector3.new(0,0,0)
	
			-- Q-TILT LOGIC
			if UIS:IsKeyDown(Enum.KeyCode.Q) then
				bg.CFrame = camera.CFrame * CFrame.Angles(math.rad(-90), 0, 0)
			else
				bg.CFrame = camera.CFrame
			end
	
