			local hrp = player.Character.HumanoidRootPart
			local targetPos = hrp.Position + Vector3.new(0, 1.5, 0)
			local currentPos = camera.CFrame.Position
			local newPos = currentPos:Lerp(targetPos, smoothness)
			local x, y, z = camera.CFrame:ToEulerAnglesXYZ()
			camera.CFrame = CFrame.new(newPos) * CFrame.Angles(x, y, z)
		end
	end)
	
	-- ✅ STABLE COLLISION (Restores default physics when OFF)
	local function applyStableCollision(character, enable)
		for _, obj in pairs(character:GetDescendants()) do
			if obj:IsA("BasePart") then
				if enable then
					obj.Massless = true
					if obj.Name ~= "HumanoidRootPart" then
						obj.CanCollide = false
					end
				else
					-- Restore Prison Life default physics
					obj.Massless = false
					obj.CanCollide = true
				end
			end
		end
	end
	
	local function setTransparency(character, value)
		for _, obj in pairs(character:GetDescendants()) do
			if obj:IsA("BasePart") or obj:IsA("Decal") or obj:IsA("Texture") then
				obj.Transparency = value
			end
		end
	end
	
	local function removeInvis()
		if invisSeat then invisSeat:Destroy() invisSeat = nil end
		if invisWeld then invisWeld:Destroy() invisWeld = nil end
	
		if player.Character then
			local char = player.Character
			applyStableCollision(char, false) -- RESTORE PHYSICS
			local hrp = char:FindFirstChild("HumanoidRootPart")
			if hrp then hrp.Transparency = 0 end
			setTransparency(char, 0)
		end
	end
	
	local function applyInvis()
		if not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then return end
		local char = player.Character
		local hrp = char.HumanoidRootPart
	
		local humanoid = char:FindFirstChildOfClass("Humanoid")
		if humanoid and humanoid.SeatPart then return end
	
		applyStableCollision(char, true) -- ACTIVATE PHYSICS
	
		local savedCFrame = hrp.CFrame
		char:MoveTo(Vector3.new(-25.95, BIG_NUMBAH, BIG_NUMBAH))
		task.wait(0.1)
	
		invisSeat = Instance.new("Seat")
		invisSeat.Name = "InvisChair"
		invisSeat.Anchored = false
		invisSeat.CanCollide = false
		invisSeat.Transparency = 1
		invisSeat.Position = Vector3.new(-25.95, BIG_NUMBAH, BIG_NUMBAH)
		invisSeat.Parent = workspace
	
		local rootPart = char:FindFirstChild("UpperTorso") or char:FindFirstChild("Torso")
		if rootPart then
			invisWeld = Instance.new("WeldConstraint")
			invisWeld.Part0 = invisSeat
			invisWeld.Part1 = rootPart
			invisWeld.Parent = invisSeat
		end
	
		invisSeat.CFrame = savedCFrame
		setTransparency(char, 0.5)
		hrp.Transparency = 1
	end
	
	local function toggleInvisibility()
		invis_on = not invis_on
		if invis_on then 
			applyInvis() 
		else 
			removeInvis() 
		end
	end
	
	script.Parent.MouseButton1Click:Connect(toggleInvisibility)
	
	-- // VEHICLE DETECTION
	local function setupVehicleCheck(char)
		local hum = char:WaitForChild("Humanoid")
		hum:GetPropertyChangedSignal("SeatPart"):Connect(function()
			if hum.SeatPart then
				if invis_on then removeInvis() end
			else
				task.wait(0.1)
				if invis_on then applyInvis() end
			end
		end)
	end
	
	player.CharacterAdded:Connect(function(char)
		task.wait(0.6)
		setupVehicleCheck(char)
		if invis_on then applyInvis() end
	end)
	
	if player.Character then
		setupVehicleCheck(player.Character)
	end
	
	script.AncestryChanged:Connect(function()
		if not script:IsDescendantOf(game) then removeInvis() end
	end)
end;
