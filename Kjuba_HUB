local function C_190()
local script = G2L["190"];
	local button = script.Parent
	local Lighting = game:GetService("Lighting")
	local Players = game:GetService("Players")
	local Debris = game:GetService("Debris")
	local Terrain = workspace:FindFirstChildOfClass("Terrain")
	
	local SM = require(script:FindFirstAncestor("KJUBAHUBB"):WaitForChild("KJUBAHUBBSettingsManager"))
	
	local enabled = SM.get("potato_mode", false)
	local loopRunning = false
	
	-- Storage for original settings
	local originalSettings = {
		Lighting = {},
		Parts = {},
		Textures = {},
		Particles = {},
		Meshes = {},
		Effects = {}
	}
	
	local darkSky = Instance.new("Sky")
	darkSky.SkyboxBk = "rbxassetid://2350402582"
	darkSky.SkyboxDn = "rbxassetid://2350402582"
	darkSky.SkyboxFt = "rbxassetid://2350402582"
	darkSky.SkyboxLf = "rbxassetid://2350402582"
	darkSky.SkyboxRt = "rbxassetid://2350402582"
	darkSky.SkyboxUp = "rbxassetid://2350402582"
	darkSky.SunTextureId = ""
	darkSky.MoonTextureId = ""
	
	local function cleanDebris()
		local objects = workspace:GetChildren()
		for i, model in pairs(objects) do
			if i % 20 == 0 then task.wait() end
	
			if model:IsA("Model") then
				local humanoid = model:FindFirstChildOfClass("Humanoid")
				if humanoid and humanoid.Health <= 0 then
					if not Players:GetPlayerFromCharacter(model) then
						Debris:AddItem(model, 0.1)
					end
				end
			elseif model:IsA("BasePart") and not model.Anchored then
				-- CHECK: Is it a seat, or part of a seat/vehicle?
				local isVehicle = model:IsA("VehicleSeat") or model:IsA("Seat") 
					or model:FindFirstAncestorOfClass("VehicleSeat") 
					or model:FindFirstAncestorOfClass("Seat")
	
				-- Only delete if it's not a player part AND not a vehicle/seat
				if not isVehicle then
					if not model:FindFirstAncestorOfClass("Model") or not Players:GetPlayerFromCharacter(model.Parent) then
						Debris:AddItem(model, 0.1)
					end
				end
			end
		end
	end
	
	local function applyUltra()
		-- Save & Apply Lighting
		originalSettings.Lighting.GlobalShadows = Lighting.GlobalShadows
		originalSettings.Lighting.Brightness = Lighting.Brightness
		originalSettings.Lighting.EnvDiffuse = Lighting.EnvironmentDiffuseScale
		originalSettings.Lighting.EnvSpecular = Lighting.EnvironmentSpecularScale
	
		Lighting.GlobalShadows = false
		Lighting.Brightness = 1
		Lighting.EnvironmentDiffuseScale = 0
		Lighting.EnvironmentSpecularScale = 0
	
		-- Sky
		local oldSky = Lighting:FindFirstChildOfClass("Sky")
		if oldSky then 
			originalSettings.Lighting.Sky = oldSky
			oldSky.Parent = nil 
		end
		darkSky.Parent = Lighting
	
		-- Process Workspace
		for _, obj in pairs(workspace:GetDescendants()) do
			-- Don't mess with Player Characters
			if Players:GetPlayerFromCharacter(obj) or obj:FindFirstAncestorOfClass("Player") then 
				continue 
			end
	
			if obj:IsA("BasePart") then
				originalSettings.Parts[obj] = {
					Material = obj.Material,
					CastShadow = obj.CastShadow,
					Reflectance = obj.Reflectance
				}
				obj.Material = Enum.Material.SmoothPlastic
				obj.CastShadow = false
				obj.Reflectance = 0
			elseif obj:IsA("Texture") or obj:IsA("Decal") then
				originalSettings.Textures[obj] = obj.Transparency
				obj.Transparency = 1
			elseif obj:IsA("ParticleEmitter") or obj:IsA("Trail") or obj:IsA("Beam") then
				originalSettings.Particles[obj] = obj.Enabled
				obj.Enabled = false
			elseif obj:IsA("MeshPart") or obj:IsA("SpecialMesh") then
				local idProp = obj:IsA("MeshPart") and "TextureID" or "TextureId"
				originalSettings.Meshes[obj] = obj[idProp]
				obj[idProp] = ""
			end
		end
	end
	
	local function restoreAll()
		-- Restore Lighting
		Lighting.GlobalShadows = originalSettings.Lighting.GlobalShadows
		Lighting.Brightness = originalSettings.Lighting.Brightness
		Lighting.EnvironmentDiffuseScale = originalSettings.Lighting.EnvDiffuse
		Lighting.EnvironmentSpecularScale = originalSettings.Lighting.EnvSpecular
	
		darkSky.Parent = nil
		if originalSettings.Lighting.Sky then
			originalSettings.Lighting.Sky.Parent = Lighting
		end
	
		-- Restore Parts
		for part, data in pairs(originalSettings.Parts) do
			if part and part.Parent then
				part.Material = data.Material
				part.CastShadow = data.CastShadow
				part.Reflectance = data.Reflectance
			end
		end
	
		-- Restore Textures
		for tex, trans in pairs(originalSettings.Textures) do
			if tex and tex.Parent then tex.Transparency = trans end
		end
	
		-- Restore Particles
		for effect, state in pairs(originalSettings.Particles) do
			if effect and effect.Parent then effect.Enabled = state end
		end
	
		-- Restore Meshes
		for mesh, id in pairs(originalSettings.Meshes) do
			if mesh and mesh.Parent then
				local idProp = mesh:IsA("MeshPart") and "TextureID" or "TextureId"
				mesh[idProp] = id
			end
		end
	
		-- Clear tables to prevent memory leaks
		originalSettings.Parts = {}
		originalSettings.Textures = {}
		originalSettings.Particles = {}
		originalSettings.Meshes = {}
	end
	
	-- MAIN BUTTON LOGIC
	button.MouseButton1Click:Connect(function()
		enabled = not enabled
		SM.set("potato_mode", enabled)
		if enabled then
			applyUltra()
			button.Text = "Potato mode🤑-ON"
	
			-- Start Loop
			task.spawn(function()
				while enabled do
					cleanDebris()
					task.wait(5)
				end
			end)
		else
			restoreAll()
			button.Text = "Normal mode🥀-OFF"
		end
	end)
	
	SM.register("potato_mode", function() return enabled end)
end;
