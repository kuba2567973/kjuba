local function C_dc()
local script = G2L["dc"];
	local RnSer = game:GetService("RunService")
	
	local cam = workspace.Camera
	
	local plr = game.Players.LocalPlayer
	
	local SM = require(script:FindFirstAncestor("KJUBAHUBB"):WaitForChild("KJUBAHUBBSettingsManager"))
	
	local txtbox = script.Parent
	local gui = txtbox.Parent
	
	local S1 = gui:WaitForChild("F70")
	local S2 = gui:WaitForChild("F80")
	local S3 = gui:WaitForChild("F90")
	local S4 = gui:WaitForChild("F100")
	local S5 = gui:WaitForChild("F110")
	local S6 = gui:WaitForChild("F120")
	
	local FT = gui:WaitForChild("FT")
	
	-- Restore saved values
	local ENABLED = SM.get("fov_enabled", true)
	local savedFov = SM.get("fov_value", nil)
	if savedFov then
		txtbox.Text = tostring(savedFov)
	end
	FT.Text = ENABLED and "ON" or "OFF"
	
	FT.Activated:Connect(function()
		ENABLED = not ENABLED
		if ENABLED == false then
			FT.Text = "OFF"
		else
			FT.Text = "ON"
		end
		SM.set("fov_enabled", ENABLED)
	end)
	
	RnSer.RenderStepped:Connect(function()
		if ENABLED then
			local spdval = tonumber(txtbox.Text)
			if spdval then
				cam.FieldOfView = spdval
			end
		end
	end)
	
	-- Register settings for auto-save
	SM.register("fov_enabled", function() return ENABLED end)
	SM.register("fov_value", function() return tonumber(txtbox.Text) end)
	
	S1.Activated:Connect(function() txtbox.Text = 70 end)
	S2.Activated:Connect(function() txtbox.Text = S2.Text end)
	S3.Activated:Connect(function() txtbox.Text = S3.Text end)
	S4.Activated:Connect(function() txtbox.Text = S4.Text end)
	S5.Activated:Connect(function() txtbox.Text = S5.Text end)
	S6.Activated:Connect(function() txtbox.Text = S6.Text end)
end;
