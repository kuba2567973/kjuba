	local Players = game:GetService("Players")
	
	local player = Players.LocalPlayer
	local mainFrame = script.Parent
	
	local menuOpen = mainFrame.Visible
	
	-- Modal fix
	local modalButton = mainFrame:FindFirstChild("ModalFix")
	if not modalButton then
		modalButton = Instance.new("TextButton")
		modalButton.Name = "ModalFix"
		modalButton.Size = UDim2.new(0, 0, 0, 0)
		modalButton.BackgroundTransparency = 1
		modalButton.Text = ""
		modalButton.Parent = mainFrame
	end
	
	local function isFirstPerson()
		local char = player.Character
		if not char or not char:FindFirstChild("Head") then return false end
	
		local camera = workspace.CurrentCamera
		local distance = (char.Head.Position - camera.CFrame.Position).Magnitude
	
		return distance < 1.5
	end
	
	local function update()
		if menuOpen then
			-- 🟢 MENU OPEN → FREE MOUSE
			modalButton.Modal = true
			UserInputService.MouseBehavior = Enum.MouseBehavior.Default
			player.CameraMode = Enum.CameraMode.Classic
	
		else
			-- 🔴 MENU CLOSED
	
			-- ❗ IMPORTANT: disable modal ONCE and leave it
			if modalButton.Modal then
				modalButton.Modal = false
			end
	
			-- ONLY lock in first person
			if isFirstPerson() then
				UserInputService.MouseBehavior = Enum.MouseBehavior.LockCenter
			else
				-- 🔥 THIS FIXES RIGHT CLICK
				UserInputService.MouseBehavior = Enum.MouseBehavior.Default
			end
		end
	end
	
	-- Toggle menu (N)
	UserInputService.InputBegan:Connect(function(input, processed)
		if not processed and input.KeyCode == Enum.KeyCode.N then
			menuOpen = not menuOpen
			mainFrame.Visible = menuOpen
			update()
		end
	end)
	
	-- ❌ REMOVED RenderStepped loop (this was breaking RMB)
	
	update()
end;
