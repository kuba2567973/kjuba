	btn6.MouseButton1Click:Connect(function() setSpeed(btn6) end)
	btn7.MouseButton1Click:Connect(function() setSpeed(btn7) end)
	btn5.MouseButton1Click:Connect(function() 
		local h = player.Character:FindFirstChild("Humanoid")
		speedInput.Text = h and tostring(math.floor(h.WalkSpeed)) or "16"
	end)
