local function C_19e()
local script = G2L["19e"];
	local plr = game.Players.LocalPlayer
	local KJUBAHUBB = plr.PlayerGui:WaitForChild("KJUBAHUBB")
	
	local SM = require(script:FindFirstAncestor("KJUBAHUBB"):WaitForChild("KJUBAHUBBSettingsManager"))
	
	local txtbox = script.Parent
	local gui = script.Parent.Parent
	
	local BL = gui:WaitForChild("BL")
	local GR = gui:WaitForChild("GR")
	local WH = gui:WaitForChild("WH")
	
	-- Restore saved color
	local savedColor = SM.get("gui_color", nil)
	if savedColor then
		txtbox.Text = savedColor
	end
	
	-- Funkce pro bezpečné odečtení 30 od barvy (aby nešla pod 0)
	local function subtract30(color)
		return Color3.fromRGB(
			math.max(0, (color.R * 255) - 30),
			math.max(0, (color.G * 255) - 30),
			math.max(0, (color.B * 255) - 30)
		)
	end
	
	local function applyCustomColor(targetColor)
		local frameColor = subtract30(targetColor)
	
		for _, obj in pairs(KJUBAHUBB:GetDescendants()) do
			if obj:IsA("Frame") and obj.Name ~= "bar" then
				obj.BackgroundColor3 = frameColor
			elseif obj:IsA("Frame") and obj.Name == "bar" then
				obj.BackgroundColor3 = targetColor
			elseif obj:IsA("TextButton") or obj:IsA("TextBox") or obj:IsA("ScrollingFrame") then
				obj.BackgroundColor3 = targetColor
				-- FIXED LINE BELOW:
			elseif obj:IsA("TextLabel") and (obj.Name == "pos1" or obj.Name == "sp") then
				obj.BackgroundColor3 = frameColor
			end
		end
	end
	
	-- Tlačítka (přidáno zpět)
	BL.Activated:Connect(function() txtbox.Text = "black" end)
	GR.Activated:Connect(function() txtbox.Text = "gray" end)
	WH.Activated:Connect(function() txtbox.Text = "white" end)
	
	-- Detekce textu a RGB
	txtbox:GetPropertyChangedSignal("Text"):Connect(function()
		local input = txtbox.Text
	
		-- 1. Zkusíme RGB (formát: 255, 0, 0)
		local r, g, b = input:match("(%d+),%s*(%d+),%s*(%d+)")
	
		if r and g and b then
			local customColor = Color3.fromRGB(tonumber(r), tonumber(g), tonumber(b))
			applyCustomColor(customColor)
			SM.set("gui_color", input)
			return 
		end
	
		-- 2. Přednastavená slova
		local lowInput = input:lower()
		if lowInput == "black" then
			applyCustomColor(Color3.fromRGB(35, 35, 35)) -- Hlavní barva pro buttony
			SM.set("gui_color", input)
		elseif lowInput == "gray" or lowInput == "grey" then
			applyCustomColor(Color3.fromRGB(130, 130, 130))
			SM.set("gui_color", input)
		elseif lowInput == "white" then
			applyCustomColor(Color3.fromRGB(255, 255, 255))
			SM.set("gui_color", input)
		end
	end)
	
	SM.register("gui_color", function() return txtbox.Text end)
	
end;
