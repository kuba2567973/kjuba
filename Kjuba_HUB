-- Require G2L wrapper
local G2L_REQUIRE = require;
local G2L_MODULES = {};
local function require(Module:ModuleScript)
    local ModuleState = G2L_MODULES[Module];
    if ModuleState then
        if not ModuleState.Required then
            ModuleState.Required = true;
            ModuleState.Value = ModuleState.Closure();
        end
        return ModuleState.Value;
    end;
    return G2L_REQUIRE(Module);
end

G2L_MODULES[G2L["2"]] = {
Closure = function()
    local script = G2L["2"];local KJUBAHUBBSettingsManager = {}

local SAVE_KEY = "KJUBAHUBBSettings_v1"
local HttpService = game:GetService("HttpService")
local Players = game:GetService("Players")

-- Registered getters: key -> function that returns current value
local getters = {}

-- Direct values set via set() method
local directValues = {}

-- Cache of loaded data
local cachedData = nil

-- Track if we've loaded yet
local hasLoaded = false

-- Register a setting with a function that returns its current value
function KJUBAHUBBSettingsManager.register(key, getValueFunc)
	getters[key] = getValueFunc
end

-- Set a value directly
function KJUBAHUBBSettingsManager.set(key, value)
	directValues[key] = value
end

-- Collect all current values from registered getters and direct values
local function collectValues()
	local data = {}
	for key, getter in pairs(getters) do
		local success, value = pcall(getter)
		if success and value ~= nil then
			data[key] = value
		end
	end
	for key, value in pairs(directValues) do
		if value ~= nil then
			data[key] = value
		end
	end
	return data
end

-- Save current state to file
function KJUBAHUBBSettingsManager.save()
	local data = collectValues()
	pcall(function()
		writefile(SAVE_KEY, HttpService:JSONEncode(data))
	end)
end

-- Load saved data from file (cached after first load)
function KJUBAHUBBSettingsManager.load()
	if cachedData then
		return cachedData
	end
	hasLoaded = true
	local success, result = pcall(function()
		if isfile(SAVE_KEY) then
			return HttpService:JSONDecode(readfile(SAVE_KEY))
		end
		return nil
	end)
	if success and result then
		cachedData = result
		return result
	end
	return nil
end

-- Get a specific saved value (used on load to restore state)
function KJUBAHUBBSettingsManager.get(key, default)
	local data = KJUBAHUBBSettingsManager.load()
	if data and data[key] ~= nil then
		return data[key]
	end
	return default
end

-- Force a fresh reload from file (clears cache)
function KJUBAHUBBSettingsManager.reload()
	cachedData = nil
	return KJUBAHUBBSettingsManager.load()
end

-- Auto-save loop: saves every 3 seconds automatically
task.spawn(function()
	while task.wait(3) do
		KJUBAHUBBSettingsManager.save()
	end
end)

-- Save on teleport/leave so no data is lost
local localPlayer = Players.LocalPlayer
if localPlayer then
	localPlayer.OnTeleport:Connect(function()
		KJUBAHUBBSettingsManager.save()
	end)
end

return KJUBAHUBBSettingsManager
end;
