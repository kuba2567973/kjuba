local function C_15b()
local script = G2L["15b"];
	-- This script should be placed inside the "es" button as a LocalScript
	local espButton = script.Parent
	local gui = espButton.Parent
	local trsButton = gui:FindFirstChild("trs")
	local tmchkButton = gui:FindFirstChild("tmchkwh")
	local rnbwButton = gui:FindFirstChild("rnbw")
	local Players = game:GetService("Players")
	local RunService = game:GetService("RunService")
	local LocalPlayer = Players.LocalPlayer
	local camera = workspace.CurrentCamera
	
	local SM = require(script:FindFirstAncestor("KJUBAHUBB"):WaitForChild("KJUBAHUBBSettingsManager"))
	
	-- === SETTINGS (WITH SAVE) ===
	local espEnabled = SM.get("esp_enabled", false)
	local tracersEnabled = SM.get("esp_tracers", false)
	local teamCheck = SM.get("esp_teamcheck", true)
	local rainbowEnabled = SM.get("esp_rainbow", false)
	
	-- Apply UI text
	espButton.Text = espEnabled and "ESP-ON" or "ESP-OFF"
	if trsButton then trsButton.Text = tracersEnabled and "Tracers-ON" or "Tracers-OFF" end
	if tmchkButton then tmchkButton.Text = teamCheck and "TeamCheck-ON" or "TeamCheck-OFF" end
	if rnbwButton then rnbwButton.Text = rainbowEnabled and "RGB-ON" or "RGB-OFF" end
	
	local espObjects = {}
	local localAttach = nil
	local playerGui = LocalPlayer:WaitForChild("PlayerGui")
	local espScreenGui = Instance.new("ScreenGui")
	espScreenGui.Name = "ESPScreenGui"
	espScreenGui.Parent = playerGui
	espScreenGui.ResetOnSpawn = false
	espScreenGui.IgnoreGuiInset = true
	
	LocalPlayer.CharacterAdded:Connect(function()
		localAttach = nil
	end)
	
	local function getLocalAttach()
		if localAttach and localAttach.Parent then return localAttach end
		local char = LocalPlayer.Character
		if not char then return nil end
		local root = char:FindFirstChild("HumanoidRootPart")
		if not root then return nil end
		local attach = root:FindFirstChild("TracerAttach0")
		if not attach then
			attach = Instance.new("Attachment")
			attach.Name = "TracerAttach0"
			attach.Parent = root
		end
		localAttach = attach
		return attach
	end
	
	local function destroyESP(player)
		if espObjects[player] then
			for _, item in pairs(espObjects[player]) do
				if item and typeof(item) == "Instance" then
					item:Destroy()
				end
			end
			espObjects[player] = nil
		end
	end
	
	local function addESP(player)
		if player == LocalPlayer then return end
		local function setup(character)
			if not character then return end
			local root = character:WaitForChild("HumanoidRootPart", 10)
			local humanoid = character:WaitForChild("Humanoid", 10)
			if not root or not humanoid then return end
			destroyESP(player)
			-- Box, Health, Highlight, Beam
			local boxFrame = Instance.new("Frame")
			boxFrame.BackgroundTransparency = 1
			boxFrame.BorderSizePixel = 0
			boxFrame.Visible = false
			boxFrame.Parent = espScreenGui
			local uistroke = Instance.new("UIStroke")
			uistroke.Thickness = 2
			uistroke.Parent = boxFrame
			local uicorner = Instance.new("UICorner")
			uicorner.CornerRadius = UDim.new(0.05, 0)
			uicorner.Parent = boxFrame
			-- Name and Dist Labels
			local nameLabel = Instance.new("TextLabel")
			nameLabel.BackgroundTransparency = 1
			nameLabel.TextScaled = false
			nameLabel.TextSize = 18
			nameLabel.TextStrokeTransparency = 0
			nameLabel.TextStrokeColor3 = Color3.fromRGB()
			nameLabel.Font = Enum.Font.MontserratBold
			nameLabel.AnchorPoint = Vector2.new(0.5, 1)
			nameLabel.Visible = false
			nameLabel.Parent = espScreenGui
			nameLabel.Text = player.Name
			local distLabel = Instance.new("TextLabel")
			distLabel.BackgroundTransparency = 1
			distLabel.TextScaled = false
			distLabel.TextSize = 18
			distLabel.TextStrokeTransparency = 0
			distLabel.TextStrokeColor3 = Color3.fromRGB()
			distLabel.Font = Enum.Font.MontserratBold
			distLabel.AnchorPoint = Vector2.new(0.5, 0)
			distLabel.Visible = false
			distLabel.Parent = espScreenGui
			local healthFrame = Instance.new("Frame")
			healthFrame.BackgroundTransparency = 1
			healthFrame.Visible = false
			healthFrame.Parent = espScreenGui
			local healthBack = Instance.new("Frame")
			healthBack.BackgroundColor3 = Color3.new(0, 0, 0)
			healthBack.BorderSizePixel = 0
			healthBack.Size = UDim2.new(1, 0, 1, 0)
			healthBack.Parent = healthFrame
			local healthBar = Instance.new("Frame")
			healthBar.BorderSizePixel = 0
			healthBar.AnchorPoint = Vector2.new(0, 1)
			healthBar.Position = UDim2.new(0, 0, 1, 0)
			healthBar.Parent = healthBack
			local highlight = Instance.new("Highlight")
			highlight.Adornee = character
			highlight.FillTransparency = 0.6
			highlight.OutlineTransparency = 0.2
			highlight.Enabled = false
			highlight.Parent = workspace
			local beam = Instance.new("Beam")
			beam.FaceCamera = true
			beam.Enabled = false
			beam.Width0 = 0.2
			beam.Width1 = 0.2
			beam.LightEmission = 1
			beam.Transparency = NumberSequence.new(0.3)
			beam.Parent = workspace
			-- Create TracerAttach1
			local tracerAttach1 = root:FindFirstChild("TracerAttach1")
			if not tracerAttach1 then
				tracerAttach1 = Instance.new("Attachment")
				tracerAttach1.Name = "TracerAttach1"
				tracerAttach1.Parent = root
			end
			espObjects[player] = {
				boxFrame = boxFrame,
				uistroke = uistroke,
				nameLabel = nameLabel,
				distLabel = distLabel,
				healthFrame = healthFrame,
				healthBar = healthBar,
				highlight = highlight,
				beam = beam,
				character = character,
				humanoid = humanoid,
				root = root
			}
		end
		player.CharacterAdded:Connect(setup)
		if player.Character then setup(player.Character) end
	end
	
	for _, player in ipairs(Players:GetPlayers()) do addESP(player) end
	Players.PlayerAdded:Connect(addESP)
	Players.PlayerRemoving:Connect(destroyESP)
	
	-- Toggles
	espButton.MouseButton1Click:Connect(function()
		espEnabled = not espEnabled
		SM.set("esp_enabled", espEnabled)
		espButton.Text = espEnabled and "ESP-ON" or "ESP-OFF"
	end)
	
	if trsButton then
		trsButton.MouseButton1Click:Connect(function()
			tracersEnabled = not tracersEnabled
			SM.set("esp_tracers", tracersEnabled)
			trsButton.Text = tracersEnabled and "Tracers-ON" or "Tracers-OFF"
		end)
	end
	
	if tmchkButton then
		tmchkButton.MouseButton1Click:Connect(function()
			teamCheck = not teamCheck
			SM.set("esp_teamcheck", teamCheck)
			tmchkButton.Text = teamCheck and "TeamCheck-ON" or "TeamCheck-OFF"
		end)
	end
	
	if rnbwButton then
		rnbwButton.MouseButton1Click:Connect(function()
			rainbowEnabled = not rainbowEnabled
			SM.set("esp_rainbow", rainbowEnabled)
			rnbwButton.Text = rainbowEnabled and "RGB-ON" or "RGB-OFF"
		end)
	end
	
	-- Register for auto-save
	SM.register("esp_enabled", function() return espEnabled end)
	SM.register("esp_tracers", function() return tracersEnabled end)
	SM.register("esp_teamcheck", function() return teamCheck end)
	SM.register("esp_rainbow", function() return rainbowEnabled end)
	
	RunService.RenderStepped:Connect(function()
		local localChar = LocalPlayer.Character
		local localRoot = localChar and localChar:FindFirstChild("HumanoidRootPart")
		local localAttachNow = getLocalAttach()
		local hue = tick() % 5 / 5
		local rainbowColor = Color3.fromHSV(hue, 1, 1)
		for player, obj in pairs(espObjects) do
			local char = obj.character
			local root = obj.root
			local humanoid = obj.humanoid
			if not char or not char.Parent or not root or not root.Parent or not humanoid or humanoid.Health <= 0 then
				obj.boxFrame.Visible = false
				obj.nameLabel.Visible = false
				obj.distLabel.Visible = false
				obj.healthFrame.Visible = false
				obj.highlight.Enabled = false
				obj.beam.Enabled = false
				continue
			end
			local onTeam = (teamCheck and player.Team == LocalPlayer.Team)
			local shouldShow = espEnabled and not onTeam
			local shouldShowTracer = tracersEnabled and not onTeam
			local activeColor = rainbowEnabled and rainbowColor or (player.TeamColor and player.TeamColor.Color or Color3.fromRGB(150, 0, 0))
			if shouldShow then
				local cf, size = char:GetBoundingBox()
				local screenPos, onScreen = camera:WorldToViewportPoint(cf.Position)
				if onScreen then
					local sizeX = size.X
					local sizeY = size.Y
					local top = camera:WorldToViewportPoint((cf * CFrame.new(0, sizeY/2, 0)).Position)
