							myHRP.CFrame = targetHRP.CFrame * CFrame.new(0, 0, 2.5)
	
							-- Útok
							forceAttack(player.Character)
	
							task.wait(0.01) -- Nutné pro registraci v Trench War
							break 
						end
					end
				end
			end
		end
	end)
	
