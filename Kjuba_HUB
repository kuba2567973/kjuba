local function C_44()
local script = G2L["44"];
	local button = script.Parent
	local Players = game:GetService("Players")
	
	local SM = require(script:FindFirstAncestor("KJUBAHUBB"):WaitForChild("KJUBAHUBBSettingsManager"))
	
	local isStunned = SM.get("stunned_enabled", false)
	button.Text = isStunned and "Stunned-ON" or "Stunned-OFF"
	local originalWalkSpeed = 16 
	-- Zde si uložíme původní stav kolizí pro každou část
	local originalCollisionStates = {}
	
	-- Funkce pro uložení/obnovení stavu kolizí
	local function manageCollisions(character, enable)
		for _, part in pairs(character:GetDescendants()) do
			if part:IsA("BasePart") and part.Name ~= "Head" and part.Name ~= "UpperTorso" and part.Name ~= "LowerTorso" and part.Name ~= "HumanoidRootPart" then
				if enable then
					-- Obnoví původní stav (pokud existuje v tabulce)
					local originalState = originalCollisionStates[part]
					if originalState ~= nil then
						part.CanCollide = originalState
					end
				else
					-- Uloží aktuální stav a nastaví CanCollide na false
					originalCollisionStates[part] = part.CanCollide
					part.CanCollide = false
				end
			end
		end
	end
	
	
	button.MouseButton1Click:Connect(function()
		local player = Players.LocalPlayer
		local character = player.Character or player.CharacterAdded:Wait() 
		local humanoid = character:FindFirstChild("Humanoid")
	
		if not humanoid then return end
	
		isStunned = not isStunned
		SM.set("stunned_enabled", isStunned)
	
		if isStunned then
			originalWalkSpeed = humanoid.WalkSpeed 
	
			humanoid.PlatformStand = true 
			humanoid.WalkSpeed = 0 
	
			-- Vypneme kolize pro končetiny
			manageCollisions(character, false)
	
			button.Text = "Stunned-ON"
		else
			humanoid.PlatformStand = false
			humanoid.WalkSpeed = originalWalkSpeed 
	
			-- Zapneme kolize zpět
			manageCollisions(character, true)
	
			button.Text = "Stunned-OFF"
		end
	end)
	
	SM.register("stunned_enabled", function() return isStunned end)
	
end;
