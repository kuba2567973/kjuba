		tool:Activate()
	
		-- Hledání RemoteEventu pro poškození (Trench War/ACS/Carbon fix)
		-- Hry často používají eventy jako "Hit", "Fire", "Damage" nebo "Remote"
		local event = tool:FindFirstChild("Hit") or tool:FindFirstChild("Damage") or tool:FindFirstChild("Fire") or tool:FindFirstChildOfClass("RemoteEvent")
	
