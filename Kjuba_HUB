local function C_157()
local script = G2L["157"];
	-- PREVENT DOUBLE RUN
	if _G.AIMBOT_RUNNING then return end
	_G.AIMBOT_RUNNING = true
	
	-- SERVICES
	local UIS = game:GetService("UserInputService")
	local RS = game:GetService("RunService")
	local Players = game:GetService("Players")
	
	local SM = require(script:FindFirstAncestor("KJUBAHUBB"):WaitForChild("KJUBAHUBBSettingsManager"))
	
	local lp = Players.LocalPlayer
	local cam = workspace.CurrentCamera
	
	local menu = script.Parent.Parent
	local aimBtn = menu:WaitForChild("ambo")
	local teamBtn = menu:WaitForChild("tmchk")
	local wallBtn = menu:WaitForChild("wchk")
	local radiustxtbox = menu:WaitForChild("fvr")
	local shwfvrad = menu:WaitForChild("shfv")
	local rnbwBtn = script.Parent.Parent:WaitForChild("rawispn")
	
	---------------------------------------------------
	-- LOCAL SETTINGS (WITH SAVE)
	---------------------------------------------------
	local aim_On = SM.get("aimbot_enabled", false)
	local aim_TC = SM.get("aimbot_teamcheck", true)
	local aim_WC = SM.get("aimbot_wallcheck", true)
	local showFOV = SM.get("aimbot_showfov", false)
	local rainbow = SM.get("aimbot_rainbow", false)
	local FOV_RADIUS = SM.get("aimbot_fov_radius", 400)
	
	local aiming = false
	local TARGET_PART = "Head"
	local lockedTarget = nil
	local hue = 0
	
	---------------------------------------------------
	-- UI SYNC
	---------------------------------------------------
	local function updateAimBtn()
		aimBtn.Text = "Aimbot-" .. (aim_On and "ON" or "OFF")
	end
	
	local function updateTeamBtn()
		teamBtn.Text = "TeamCheck-" .. (aim_TC and "ON" or "OFF")
	end
	
	local function updateWallBtn()
		wallBtn.Text = "WallCheck-" .. (aim_WC and "ON" or "OFF")
	end
	
	local function updateFovUI()
		shwfvrad.Text = "ShowFOV-" .. (showFOV and "ON" or "OFF")
		radiustxtbox.Text = tostring(FOV_RADIUS)
	end
	
	local function updateRnbwBtn()
		if rnbwBtn then
			rnbwBtn.Text = "RGB-" .. (rainbow and "ON" or "OFF")
		end
	end
	
	updateAimBtn()
	updateTeamBtn()
	updateWallBtn()
	updateFovUI()
	updateRnbwBtn()
	
	---------------------------------------------------
	-- FOV CIRCLE
	---------------------------------------------------
	local screenGui = Instance.new("ScreenGui", lp:WaitForChild("PlayerGui"))
	screenGui.Name = "FOVCircle"
	screenGui.ResetOnSpawn = false
	screenGui.IgnoreGuiInset = true
	
	local fovCircle = Instance.new("Frame", screenGui)
	fovCircle.AnchorPoint = Vector2.new(0.5, 0.5)
	fovCircle.BackgroundTransparency = 1
	
	local corner = Instance.new("UICorner", fovCircle)
	corner.CornerRadius = UDim.new(1, 0)
	
	local stroke = Instance.new("UIStroke", fovCircle)
	stroke.Thickness = 2
	stroke.Color = Color3.fromRGB(255, 0, 0)
	
	local function updateVisuals()
		local viewport = cam.ViewportSize
		fovCircle.Visible = showFOV
		fovCircle.Position = UDim2.fromOffset(viewport.X / 2, viewport.Y / 2)
		fovCircle.Size = UDim2.fromOffset(FOV_RADIUS * 2, FOV_RADIUS * 2)
	
		if rainbow then
			hue = (tick() % 5) / 5
			stroke.Color = Color3.fromHSV(hue, 1, 1)
		else
			stroke.Color = Color3.fromRGB(255, 0, 0)
		end
	end
	
	---------------------------------------------------
	-- CORE
	---------------------------------------------------
	local function canSee(char, part)
		if not aim_WC then return true end
	
		local params = RaycastParams.new()
		params.FilterType = Enum.RaycastFilterType.Exclude
		params.FilterDescendantsInstances = {lp.Character, cam}
	
		local result = workspace:Raycast(
			cam.CFrame.Position,
			(part.Position - cam.CFrame.Position),
			params
		)
	
		return result == nil or result.Instance:IsDescendantOf(char)
	end
	
	local function getTarget()
		if not aim_On then return nil end
	
		local closestDist = FOV_RADIUS
		local closestPart = nil
		local center = cam.ViewportSize / 2
	
		for _, plr in ipairs(Players:GetPlayers()) do
			-- Added the ForceField check here
			if plr == lp or (aim_TC and plr.Team == lp.Team) then continue end
	
			local char = plr.Character
			local part = char and char:FindFirstChild(TARGET_PART)
			local hum = char and char:FindFirstChildOfClass("Humanoid")
			local hasFF = char and char:FindFirstChildOfClass("ForceField") -- Check for FF
	
			-- Ensure the player exists, is alive, and DOES NOT have a ForceField
			if part and hum and hum.Health > 0 and not hasFF then
				local screenPos, onScreen = cam:WorldToViewportPoint(part.Position)
	
				if onScreen then
					local dist = (Vector2.new(screenPos.X, screenPos.Y) - center).Magnitude
	
					if dist < closestDist and canSee(char, part) then
						closestDist = dist
						closestPart = part
					end
				end
			end
		end
	
		return closestPart
	end
	
	---------------------------------------------------
	-- BUTTONS
	---------------------------------------------------
	aimBtn.MouseButton1Click:Connect(function()
		aim_On = not aim_On
		SM.set("aimbot_enabled", aim_On)
		updateAimBtn()
	end)
	
	teamBtn.MouseButton1Click:Connect(function()
		aim_TC = not aim_TC
		SM.set("aimbot_teamcheck", aim_TC)
		updateTeamBtn()
	end)
	
	wallBtn.MouseButton1Click:Connect(function()
		aim_WC = not aim_WC
		SM.set("aimbot_wallcheck", aim_WC)
		updateWallBtn()
	end)
	
	shwfvrad.MouseButton1Click:Connect(function()
		showFOV = not showFOV
		SM.set("aimbot_showfov", showFOV)
		updateFovUI()
	end)
	
	if rnbwBtn then
		rnbwBtn.MouseButton1Click:Connect(function()
			rainbow = not rainbow
			SM.set("aimbot_rainbow", rainbow)
			updateRnbwBtn()
		end)
	end
	
	radiustxtbox.FocusLost:Connect(function()
		local num = tonumber(radiustxtbox.Text)
		if num then
			FOV_RADIUS = math.clamp(num, 1, 5000)
			SM.set("aimbot_fov_radius", FOV_RADIUS)
			updateFovUI()
		end
	end)
	
	-- Register for auto-save
	SM.register("aimbot_enabled", function() return aim_On end)
	SM.register("aimbot_teamcheck", function() return aim_TC end)
	SM.register("aimbot_wallcheck", function() return aim_WC end)
	SM.register("aimbot_showfov", function() return showFOV end)
	SM.register("aimbot_rainbow", function() return rainbow end)
	SM.register("aimbot_fov_radius", function() return FOV_RADIUS end)
	
	UIS.InputBegan:Connect(function(i, g)
		if not g and i.UserInputType == Enum.UserInputType.MouseButton2 then
			aiming = true
		end
	end)
	
	UIS.InputEnded:Connect(function(i)
		if i.UserInputType == Enum.UserInputType.MouseButton2 then
			aiming = false
			lockedTarget = nil
		end
	end)
	
	---------------------------------------------------
	-- LOOP
	---------------------------------------------------
	RS.RenderStepped:Connect(function()
		updateVisuals()
	
		if not aim_On or not aiming then
			lockedTarget = nil
			return
		end
	
		if lockedTarget then
			local char = lockedTarget.Parent
			local hum = char and char:FindFirstChildOfClass("Humanoid")
			local plr = Players:GetPlayerFromCharacter(char)
	
			if not hum or hum.Health <= 0 or (aim_TC and plr.Team == lp.Team) or not canSee(char, lockedTarget) then
				lockedTarget = nil
			end
		end
	
		if not lockedTarget then
			lockedTarget = getTarget()
		end
	
		if lockedTarget then
			cam.CFrame = CFrame.new(cam.CFrame.Position, lockedTarget.Position)
		end
	end)
end;
task.spawn(C_157);
