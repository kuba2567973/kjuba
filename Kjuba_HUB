local function C_11c()
local script = G2L["11c"];
	-- === PRISON LIFE NOCLIP WITH BUTTON + BYPASS + SMOOTH RESET ===
	local RunService = game:GetService("RunService")
	local Players = game:GetService("Players")
	
	local SM = require(script:FindFirstAncestor("KJUBAHUBB"):WaitForChild("KJUBAHUBBSettingsManager"))
	
	local player = Players.LocalPlayer
	local noclipButton = script.Parent   -- Script must be inside your TextButton
	
	-- Restore saved state
	local noclipEnabled = SM.get("noclip_enabled", false)
	noclipButton.Text = noclipEnabled and "Noclip-ON" or "Noclip-OFF"
	
	-- ================== BYPASS (keeps Head from fighting back) ==================
	local function applyBypass()
		local char = player.Character
		if not char then return end
	
		for _, part in ipairs(char:GetDescendants()) do
			if (part:IsA("BasePart") or part:IsA("MeshPart")) and 
				(part.Name == "Head" or part.Name == "Torso" or part.Name == "UpperTorso") then
	
				part.CanCollide = false
	
				-- Block the game from forcing it back
				part:GetPropertyChangedSignal("CanCollide"):Connect(function()
					if part.CanCollide == true then
						part.CanCollide = false
					end
				end)
			end
		end
	end
	
	-- ================== NOCLIP LOOP ==================
	RunService.Heartbeat:Connect(function()
		if not noclipEnabled or not player.Character then return end
	
		local char = player.Character
	
		for _, part in ipairs(char:GetDescendants()) do
			if part:IsA("BasePart") or part:IsA("MeshPart") then
				if part.CanCollide then
					part.CanCollide = false
				end
			end
		end
	
		-- Extra force on Head & Torso
		local head = char:FindFirstChild("Head")
		if head then head.CanCollide = false end
	
		local torso = char:FindFirstChild("Torso") or char:FindFirstChild("UpperTorso")
		if torso then torso.CanCollide = false end
	end)
	
	-- ================== BUTTON TOGGLE + BETTER RESET ==================
	noclipButton.MouseButton1Click:Connect(function()
		noclipEnabled = not noclipEnabled
		SM.set("noclip_enabled", noclipEnabled)
	
		if noclipEnabled then
			noclipButton.Text = "Noclip-ON"
	
			if player.Character then
				applyBypass()
			end
		else
			noclipButton.Text = "Noclip-OFF"
	
			-- === IMPORTANT: Clean reset when turning OFF ===
			if player.Character then
				local char = player.Character
				local hum = char:FindFirstChildOfClass("Humanoid")
				local root = char:FindFirstChild("HumanoidRootPart")
	
				task.wait(0.1)  -- small delay so physics settles
	
				-- Reset all collisions
				for _, part in ipairs(char:GetDescendants()) do
					if part:IsA("BasePart") or part:IsA("MeshPart") then
						part.CanCollide = true
					end
				end
	
				-- Fix the stiff/blocky movement
				if hum then
					hum.PlatformStand = false
					hum:ChangeState(Enum.HumanoidStateType.GettingUp)
					task.wait(0.1)
					hum:ChangeState(Enum.HumanoidStateType.Running)   -- Force normal walking state
				end
	
				-- Optional: Small jump to reset physics fully
				if root then
					root.Velocity = root.Velocity + Vector3.new(0, 5, 0)
				end
			end
		end
	end)
	
	-- Register for auto-save
	SM.register("noclip_enabled", function() return noclipEnabled end)
	
	-- ================== RESPAWN SUPPORT ==================
	player.CharacterAdded:Connect(function()
		task.wait(1.2)
		if noclipEnabled and player.Character then
			applyBypass()
		end
	end)
	
	if player.Character then
		task.wait(0.5)
		applyBypass()
	end
end;
