		connection = button.MouseButton1Click:Connect(function()
			if not character or not character.Parent then connection:Disconnect() return end
			local animateScript = character:FindFirstChild("Animate")
			local animNames = {"idle", "walk", "run", "swim", "jump", "fall"}
	
			if not isEmoting then
				animTrack:Play()
				animTrack:AdjustSpeed(1.676767)
				sound.TimePosition = 0
				sound:Play()
	
				if animateScript then
					for _, name in pairs(animNames) do
						local folder = animateScript:FindFirstChild(name)
						if folder then
							local animObj = folder:FindFirstChildOfClass("Animation")
							if animObj then
								originalIds[name] = animObj.AnimationId 
								animObj.AnimationId = animObject.AnimationId 
							end
						end
					end
				end
