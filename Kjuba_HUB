	btn1.MouseButton1Click:Connect(function() speedInput.Text = "1" end)
	btn5.MouseButton1Click:Connect(function() speedInput.Text = "5" end)
	btn10.MouseButton1Click:Connect(function() speedInput.Text = "10" end)
	
	local function teleportToPlayer()
		local input = userBox.Text:lower()
		local duration = tonumber(speedInput.Text) or 1
	
		if input == "" then return end
	
		local targetPlayer = nil
		for _, plr in ipairs(Players:GetPlayers()) do
			if plr ~= lp then
				if plr.Name:lower():sub(1, #input) == input or plr.DisplayName:lower():sub(1, #input) == input then
					targetPlayer = plr
					break 
				end
			end
		end
	
		if targetPlayer then
			local char = lp.Character
			local root = char and char:FindFirstChild("HumanoidRootPart")
			local hum = char and char:FindFirstChildOfClass("Humanoid")
	
			if root and hum then
				task.spawn(function()
					local originalText = btn.Text
					btn.Text = "SCANNING..."
	
					-- 1. Try to find the target's position (even if character isn't loaded)
					-- If the player exists, we use their 'Character' reference even if it's currently nil on our screen
					local targetRoot = nil
	
					-- Loop to force-load the area by moving closer if necessary
					for i = 1, 5 do -- Try 5 "stage" jumps to find them
						if targetPlayer.Character and targetPlayer.Character:FindFirstChild("HumanoidRootPart") then
							targetRoot = targetPlayer.Character.HumanoidRootPart
							break
						end
	
						-- If they aren't found, "Ghost Jump" toward the center or a random player to refresh stream
						btn.Text = "REFRESHING..."
						lp:RequestStreamAroundAsync(Vector3.new(0,0,0)) -- Try to refresh global stream
						task.wait(0.5)
					end
	
					if targetPlayer.Character and targetPlayer.Character:FindFirstChild("HumanoidRootPart") then
						targetRoot = targetPlayer.Character.HumanoidRootPart
	
						btn.Text = "MOVING..."
						local targetCFrame = targetRoot.CFrame * CFrame.new(0, 0, 3)
						local info = TweenInfo.new(duration, Enum.EasingStyle.Linear)
	
						hum:ChangeState(Enum.HumanoidStateType.Physics)
	
						local tween = TweenService:Create(root, info, {CFrame = targetCFrame})
						tween:Play()
	
						tween.Completed:Connect(function()
							hum:ChangeState(Enum.HumanoidStateType.GettingUp)
							btn.Text = originalText
						end)
					else
						btn.Text = "NOT FOUND"
						task.wait(1.5)
						btn.Text = originalText
					end
				end)
			end
		end
	end
	
	btn.MouseButton1Click:Connect(teleportToPlayer)
	
	SM.register("tp_anim_speed", function() return tonumber(speedInput.Text) end)
