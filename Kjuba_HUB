	task.spawn(function()
		while true do
			task.wait(killDelay)
			if auraEnabled and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
				local myHRP = LocalPlayer.Character.HumanoidRootPart
	
				for _, player in pairs(Players:GetPlayers()) do
					if canAttack(player) then
						local targetHRP = player.Character:FindFirstChild("HumanoidRootPart")
						if targetHRP then
							-- Teleportace těsně za záda
							myHRP.CFrame = targetHRP.CFrame * CFrame.new(0, 0, 2.5)
	
							-- Útok
							forceAttack(player.Character)
	
							task.wait(0.01) -- Nutné pro registraci v Trench War
							break 
						end
					end
				end
			end
		end
	end)
	
	-- 4. TLAČÍTKA
	auraButton.MouseButton1Click:Connect(function()
